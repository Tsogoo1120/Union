# Public site URL for canonical links, Open Graph, JSON-LD, and metadataBase.
# Example: https://your-domain.mn
NEXT_PUBLIC_SITE_URL=

# ─── Email notifications (Resend) ────────────────────────────────────────────
# Sign up at https://resend.com → API Keys → "Create API Key".
# Free tier: 3,000 emails/month, ~10 emails/second.
RESEND_API_KEY=

# "From" header. In Resend's sandbox you can use `onboarding@resend.dev`,
# but it will ONLY deliver to the email address you signed up with.
# In production, verify a domain in Resend and use it here:
#   EMAIL_FROM="Union <noreply@your-domain.mn>"
EMAIL_FROM=

# ─── Cron secret ─────────────────────────────────────────────────────────────
# Used by /api/cron/subscription-expiring to authenticate Vercel Cron requests.
# Generate a random value, e.g. `openssl rand -hex 32`, and set the SAME
# value in Vercel → Project Settings → Environment Variables.
CRON_SECRET=
